{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "assignees": ["davide"],
  "extends": [":semanticCommits", "config:best-practices"],
  "packageRules": [
    {
      "automerge": true,
      "matchFileNames": [".devcontainer/**", ".forgejo/**"],
      "matchUpdateTypes": ["digest", "minor", "patch", "pin"]
    }
  ],
  // Raise limit or there are situations where we can't keep up with the number
  // of deps to update.
  "prHourlyLimit": 4
}
